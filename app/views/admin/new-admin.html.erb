<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Novo Usuario - NextFit Admin</title>
    <% content_for :head do %>
        <%= stylesheet_link_tag "student_new", "data-turbo-track": "reload" %>
    <% end %>
</head>
<body>
    <!-- SEÇÃO: DADOS DE ACESSO (users) -->
    <div class="form-section">
        <div class="form-section__header">
            <div class="form-section__icon">
                <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <div>
                <div class="form-section__title">Dados de Acesso</div>
                <div class="form-section__subtitle">Credenciais de login — tabela <code>users</code></div>
            </div>
        </div>

        <div class="form-grid">
            <!-- users.cpf -->
            <div class="form-group">
                <label class="form-label" for="cpf">
                    CPF <sup>*</sup>
                </label>
                <div class="form-input-wrapper">
                    <svg class="form-input-icon" viewBox="0 0 24 24" aria-hidden="true"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                    <input
                        type="text"
                        id="cpf"
                        name="user[cpf]"
                        class="form-input"
                        placeholder="000.000.000-00"
                        autocomplete="off"
                        maxlength="14"
                        required
                    >
                </div>
                <span class="form-hint">Usado como login no aplicativo.</span>
            </div>

            <!-- users.role -->
            <div class="form-group">
                <label class="form-label" for="role">
                    Perfil de acesso <sup>*</sup>
                </label>
                <div class="form-select-wrapper">
                    <select id="role" name="user[role]" class="form-select" required>
                        <option value="" disabled selected>Selecione...</option>
                        <option value="student" selected>Aluno</option>
                        <option value="admin">Administrador</option>
                    </select>
                    <svg class="form-select-arrow" viewBox="0 0 24 24" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                </div>
            </div>

            <div class="form-divider form-col-full"></div>

            <!-- users.password_digest (password) -->
            <div class="form-group">
                <label class="form-label" for="password">
                    Senha <sup>*</sup>
                </label>
                <div class="form-input-wrapper">
                    <svg class="form-input-icon" viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    <input
                        type="password"
                        id="password"
                        name="user[password]"
                        class="form-input"
                        placeholder="Mínimo 8 caracteres"
                        autocomplete="new-password"
                        minlength="8"
                        required
                    >
                </div>
            </div>

            <!-- password confirmation -->
            <div class="form-group">
                <label class="form-label" for="password_confirmation">
                    Confirmar senha <sup>*</sup>
                </label>
                <div class="form-input-wrapper">
                    <svg class="form-input-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    <input
                        type="password"
                        id="password_confirmation"
                        name="user[password_confirmation]"
                        class="form-input"
                        placeholder="Repita a senha"
                        autocomplete="new-password"
                        required
                    >
                </div>
            </div>
        </div>
    </div>

        <!-- AÇÕES DO FORMULÁRIO -->
    <div class="form-actions">
        <button type="reset" class="btn-ghost">
            Limpar campos
        </button>
        <button type="submit" class="btn-primary">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
            Salvar aluno
        </button>
    </div>